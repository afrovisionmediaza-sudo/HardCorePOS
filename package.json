{
  "name": "hardcorepos",
  "version": "1.0.0",
  "description": "HardCore Tech - Fiscal POS & Repair Management System",
  "author": "HardCore Tech",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "launcher": "electron launcher.js",
    "dist": "electron-builder --win --x64",
    "dist:mac": "electron-builder --mac --x64",
    "dist:all": "electron-builder --win --mac",
    "update:check": "node update-checker.js"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.1.7",
    "electron-log": "^5.0.1"
  },
  "build": {
    "appId": "com.hardcore.pos",
    "productName": "HardCorePOS",
    "publisherName": "HardCore Tech",
    "directories": {
      "output": "installers"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.icns"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "hardcoretech",
        "repo": "fiscalpos"
      }
    ]
  }
}